# Copy to .env.local and fill in values. Never commit .env.local.
# Rotate API keys periodically; revoke and replace if exposed.

# Required for chat, RAG, and ingest script
OPENAI_API_KEY=

# Optional: for /api/api-tool (weather)
WEATHER_API_KEY=

# Optional: for /api/web-search-tool
ANTHROPIC_API_KEY=

# Optional: for /api/client-side-tools (ImageKit). Keep IMAGEKIT_PRIVATE_KEY server-side only.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional: for email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
YOUR_EMAIL=
